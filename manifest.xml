<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xsi:type="TaskPaneApp">

  <Id>50a304bd-69e2-48ca-ae2b-2da23d8b2c5f</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>GSM Law IT</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="ND Doc Stamper"/>
  <Description DefaultValue="Stamps NetDocuments doc number and version on save"/>
  <IconUrl DefaultValue="https://jzhanggsms.github.io/nd-stamper/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://jzhanggsms.github.io/nd-stamper/icon-80.png"/>
  <SupportUrl DefaultValue="https://jzhanggsms.github.io/nd-stamper"/>

  <AppDomains>
    <AppDomain>https://jzhanggsms.github.io</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Document"/>
  </Hosts>

  <DefaultSettings>
    <SourceLocation DefaultValue="https://jzhanggsms.github.io/nd-stamper/taskpane.html"/>
  </DefaultSettings>

  <Permissions>ReadWriteDocument</Permissions>

  <VersionOverrides
    xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
    xsi:type="VersionOverridesV1_0">

    <Hosts>
      <Host xsi:type="Document">
        <DesktopFormFactor>
          <FunctionFile resid="Commands.Url"/>

          <!-- Ribbon button in the Home tab -->
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="NDStamperGroup">
                <Label resid="GroupLabel"/>
                <Icon>
                  <bt:Image size="16" resid="icon-16"/>
                  <bt:Image size="32" resid="icon-32"/>
                  <bt:Image size="80" resid="icon-80"/>
                </Icon>
                <Control xsi:type="Button" id="StampButton">
                  <Label resid="StampButtonLabel"/>
                  <Supertip>
                    <Title resid="StampButtonLabel"/>
                    <Description resid="StampButtonDesc"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="icon-16"/>
                    <bt:Image size="32" resid="icon-32"/>
                    <bt:Image size="80" resid="icon-80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>stampNow</FunctionName>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>

        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="icon-16" DefaultValue="https://jzhanggsms.github.io/nd-stamper/icon-32.png"/>
        <bt:Image id="icon-32" DefaultValue="https://jzhanggsms.github.io/nd-stamper/icon-32.png"/>
        <bt:Image id="icon-80" DefaultValue="https://jzhanggsms.github.io/nd-stamper/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://jzhanggsms.github.io/nd-stamper/commands.html"/>
        <bt:Url id="Taskpane.Url" DefaultValue="https://jzhanggsms.github.io/nd-stamper/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="AddInName" DefaultValue="ND Doc Stamper"/>
        <bt:String id="GroupLabel" DefaultValue="ND Stamper"/>
        <bt:String id="StampButtonLabel" DefaultValue="Stamp ND Info"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="AddInDescription" DefaultValue="Stamps NetDocuments doc number and version on save"/>
        <bt:String id="StampButtonDesc" DefaultValue="Manually stamp the NetDocuments document number and version at the end of this document"/>
      </bt:LongStrings>
    </Resources>

    <VersionOverrides
      xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides/1.1"
      xsi:type="VersionOverridesV1_1">

      <Hosts>
        <Host xsi:type="Document">
          <DesktopFormFactor>
            <Runtimes>
              <Runtime resid="Commands.Url" lifetime="short"/>
            </Runtimes>
            <FunctionFile resid="Commands.Url"/>

            <!-- Auto-stamp on save -->
            <ExtensionPoint xsi:type="LaunchEvent">
              <LaunchEvents>
                <LaunchEvent Type="OnDocumentBeforeSave" FunctionName="onDocumentBeforeSave"/>
              </LaunchEvents>
            </ExtensionPoint>

            <!-- Ribbon button -->
            <ExtensionPoint xsi:type="PrimaryCommandSurface">
              <OfficeTab id="TabHome">
                <Group id="NDStamperGroup">
                  <Label resid="GroupLabel"/>
                  <Icon>
                    <bt:Image size="16" resid="icon-16"/>
                    <bt:Image size="32" resid="icon-32"/>
                    <bt:Image size="80" resid="icon-80"/>
                  </Icon>
                  <Control xsi:type="Button" id="StampButton">
                    <Label resid="StampButtonLabel"/>
                    <Supertip>
                      <Title resid="StampButtonLabel"/>
                      <Description resid="StampButtonDesc"/>
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="icon-16"/>
                      <bt:Image size="32" resid="icon-32"/>
                      <bt:Image size="80" resid="icon-80"/>
                    </Icon>
                    <Action xsi:type="ExecuteFunction">
                      <FunctionName>stampNow</FunctionName>
                    </Action>
                  </Control>
                </Group>
              </OfficeTab>
            </ExtensionPoint>

          </DesktopFormFactor>
        </Host>
      </Hosts>

      <Resources>
        <bt:Images>
          <bt:Image id="icon-16" DefaultValue="https://jzhanggsms.github.io/nd-stamper/icon-32.png"/>
          <bt:Image id="icon-32" DefaultValue="https://jzhanggsms.github.io/nd-stamper/icon-32.png"/>
          <bt:Image id="icon-80" DefaultValue="https://jzhanggsms.github.io/nd-stamper/icon-80.png"/>
        </bt:Images>
        <bt:Urls>
          <bt:Url id="Commands.Url" DefaultValue="https://jzhanggsms.github.io/nd-stamper/commands.html"/>
          <bt:Url id="Taskpane.Url" DefaultValue="https://jzhanggsms.github.io/nd-stamper/taskpane.html"/>
        </bt:Urls>
        <bt:ShortStrings>
          <bt:String id="AddInName" DefaultValue="ND Doc Stamper"/>
          <bt:String id="GroupLabel" DefaultValue="ND Stamper"/>
          <bt:String id="StampButtonLabel" DefaultValue="Stamp ND Info"/>
        </bt:ShortStrings>
        <bt:LongStrings>
          <bt:String id="AddInDescription" DefaultValue="Stamps NetDocuments doc number and version on save"/>
          <bt:String id="StampButtonDesc" DefaultValue="Manually stamp the NetDocuments document number and version at the end of this document"/>
        </bt:LongStrings>
      </Resources>

    </VersionOverrides>

  </VersionOverrides>

</OfficeApp>